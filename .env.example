# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Postgres (from Neon / Supabase / Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server
PORT=3000
NODE_ENV=development       # change to production when deployed
CACHE_TTL_DAYS=7           # how long to keep cached results
ALLOWED_ORIGIN=https://yourdomain.com   # CORS in prod (optional)
